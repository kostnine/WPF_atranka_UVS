<Window x:Class="ThreadGeneratorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thread Generator" Height="600" Width="600"
        WindowStartupLocation="CenterScreen" Visibility="Visible" ShowInTaskbar="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- atsaku selektorius -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Thread kiekis:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="ThreadCountTextBox" Text="5" Width="50" VerticalAlignment="Center"/>
            <TextBlock Text="(2-15)" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Gray"/>
        </StackPanel>
        
        <!-- Kontrolės mygtukai -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="StartButton" Content="Start" Width="80" Height="30" Margin="0,0,10,0" Click="StartButton_Click"/>
            <Button x:Name="StopButton" Content="Stop" Width="80" Height="30" IsEnabled="False" Click="StopButton_Click"/>
        </StackPanel>
        
        <!-- Statusas -->
        <TextBlock Grid.Row="2" x:Name="StatusTextBlock" Text="Pasiruošęs" Margin="0,0,0,10" FontWeight="Bold"/>
        
        <!-- ListView rezultatams-->
        <ListView Grid.Row="3" x:Name="ResultsListView">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Thread ID" DisplayMemberBinding="{Binding ThreadId}" Width="100"/>
                    <GridViewColumn Header="Sugeneruota eilutė" DisplayMemberBinding="{Binding GeneratedString}" Width="200"/>
                    <GridViewColumn Header="Laikas" DisplayMemberBinding="{Binding Timestamp}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
